{
	"servers": {
		"firebase-mcp-server": {
			"command": "npx",
			"args": [
				"-y",
				"firebase-tools@latest",
				"mcp"
			],
			"type": "stdio"
		},
		"shadcn": {
			"command": "npx",
			"args": [
				"shadcn@latest",
				"mcp"
			],
			"type": "stdio"
		},
		"io.github.vercel/next-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"next-devtools-mcp@0.3.6"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.3.6"
		}
	},
	"inputs": []
}